# Firebase configuration — copy this file to .env and fill in your values.
# Get these from the Firebase Console → Project Settings → Your apps → Web app.
# See README.md → "Firebase Setup" for full step-by-step instructions.

VITE_FIREBASE_API_KEY=your-api-key-here
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789012
VITE_FIREBASE_APP_ID=1:123456789012:web:abcdef123456

# The email address that has admin access to the Admin Panel.
# This must be a real email that can receive verification emails.
VITE_ADMIN_EMAIL=your-admin@example.com
